{
  "Export": {
    "Mode": "Live",
    "OutputDirectory": "./output",
    "ExportedFileName": "exported-import.csv",
    "FailedRecordsFileName": "failed-records.csv",
    "LogFileName": "export.log"
  },
  "Browser": {
    "Headless": false,
    "SlowMo": 0,
    "LoginUrl": "https://www.fenster.dk/",
    "ListPageUrl": "https://www.fenster.dk/subscription_list",
    "NavigationTimeoutMs": 60000,
    "WaitForManualLogin": true,
    "ManualLoginPrompt": "Log in to the website, navigate to the subscription list page, then press ENTER to continue.",
    "MaxListPages": 500
  },
  "Selectors": {
    "ListPage": {
      "TableRows": "#subscription_list_table tbody tr",
      "DetailLink": "a[href*='subscription_edit']",
      "CustomerColumnIndex": 1,
      "PaginationNav": "nav.mt-5[aria-label*='Page navigation'], nav[aria-label*='Page navigation']",
      "PaginationLinks": "nav.mt-5[aria-label*='Page navigation'] a.page-link, nav[aria-label*='Page navigation'] a.page-link",
      "NextPageLink": "nav.mt-5[aria-label*='Page navigation'] ul.pagination li.page-item:not(.disabled) a.page-link[href*='page='], nav[aria-label*='Page navigation'] ul.pagination li.page-item:not(.disabled) a.page-link[href*='page=']",
      "NextPageLinkText": "næste"
    },
    "DetailPage": {
      "TaskFormRow": ".task_form_row",
      "TaskSemanticMeaning": "input[name$='-semantic_meaning']",
      "TaskPrice": "input[name$='-price']",
      "TaskDuration": "input[name$='-duration']",
      "TaskIntervalMultiplier": "select[name$='-interval_multiplier']",
      "TaskStaged": "input[name$='-staged']",
      "TaskCategory": "input[name$='-category']",
      "TaskCustomerPresence": "input[name$='-customer_presence_required']",
      "BaseInterval": "#id_base_interval",
      "BaseStartWeek": "#id_base_start_week",
      "FixedTimeOfDay": "#id_fixed_time_of_day",
      "AddressComment": "#id_address_comment",
      "BillingTextarea": "textarea[name='billing_textarea']"
    }
  }
}
